# Copy to backend/.env and adjust for your deployment.

# SQLAlchemy database URL. Defaults to a local SQLite file next to the app.
# PLANTPALS_DATABASE_URL=sqlite:///./plantpals.db

# Absolute, publicly reachable base URL of this API. Used to build photo URLs
# that the mobile app can load. Leave empty in local dev (derived from the request).
# PLANTPALS_PUBLIC_BASE_URL=https://api.yourdomain.com
